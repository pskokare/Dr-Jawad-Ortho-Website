            <!-- Add this CSS for marquee animation -->
            <style>
                @keyframes marquee {
                    0% {
                        transform: translateX(0);
                    }

                    100% {
                        transform: translateX(-50%);
                    }
                }

                .animate-marquee {
                    animation: marquee 40s linear infinite;
                    width: fit-content;
                }

                .animate-marquee:hover {
                    animation-play-state: paused;
                }

                /* Optional: Add smooth pause on hover for individual items */
                .group:hover {
                    z-index: 20;
                }
            </style>




